x <- base$horas_estudio
n <- length(x)
n
k <- 1 + 3.322 * log10(n)
k
round(k)
round(k,3)
ceiling(k)
R <- max(x) - min(x)
R
A <- R / k
A
breaks <- seq(from = min(x), to = max(x), length.out = k + 1)
breaks
seq(1,40)
1:40
intervalos <- cut(x, breaks = breaks, include.lowest = TRUE, right = FALSE)
intervalos <- cut(x, breaks = breaks, include.lowest = TRUE, right = FALSE)
intervalos
fi <- table(intervalos)
fi
hi <- prop.table(fi)
Fi <- cumsum(fi)
TY <- 1:40
sum(TY)
cumsum(TY)
