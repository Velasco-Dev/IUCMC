# 7. RESUMEN DE VARIAS NUMERICAS
##############################
numericas <- sapply(base, is.numeric)
base_num <- base[, numericas]
summary(base_num)
sapply(base_num, mean, na.rm = TRUE)
sapply(base_num, median, na.rm = TRUE)
sapply(base_num, sd, na.rm = TRUE)
names(base_num)
summary(base_num)
sapply(base_num, sd, na.rm = TRUE)
